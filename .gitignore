# Git 忽略配置

# 系统文件
.DS_Store
Thumbs.db

# 日志文件
*.log
logs/

# 临时文件
tmp/
temp/
*.tmp

# 配置文件（敏感信息）
*.env
.env.local
*.secret.json

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# 构建输出
dist/
build/
*.egg-info/
